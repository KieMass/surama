rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    // Each user can only read and write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Services ───────────────────────────────────────────────────────────
    // Anyone (including unauthenticated visitors) can read active listings.
    // Only authenticated providers (role verified via user doc) can create
    // or modify their own listings.
    match /services/{serviceId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.providerId == request.auth.uid
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'provider'
                    && request.resource.data.price is number
                    && request.resource.data.price >= 0
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 200
                    && request.resource.data.description is string
                    && request.resource.data.description.size() <= 2000;
      allow update, delete: if request.auth != null
                             && resource.data.providerId == request.auth.uid;
    }

    // ── Requests ───────────────────────────────────────────────────────────
    // Consumers can create a request for themselves and read their own.
    // Providers can read and update (but not create) requests where they are
    // the named provider. Consumers may also update for a limited set of
    // status transitions (cancel, confirm completion, dispute completion).
    match /requests/{requestId} {
      allow create: if request.auth != null
                    && request.resource.data.consumerId == request.auth.uid
                    && request.resource.data.providerId != request.auth.uid
                    && (request.resource.data.price == null
                        || (request.resource.data.price is number
                            && request.resource.data.price >= 0))
                    && (!('message' in request.resource.data)
                        || request.resource.data.message.size() <= 1000);

      allow read: if request.auth != null
                  && (resource.data.consumerId == request.auth.uid
                      || resource.data.providerId == request.auth.uid);

      // Providers can update any field except the four immutable identity fields.
      allow update: if request.auth != null
                    && resource.data.providerId == request.auth.uid
                    && !("consumerId"    in request.resource.data.diff(resource.data).affectedKeys())
                    && !("providerId"    in request.resource.data.diff(resource.data).affectedKeys())
                    && !("serviceId"     in request.resource.data.diff(resource.data).affectedKeys())
                    && !("consumerEmail" in request.resource.data.diff(resource.data).affectedKeys());

      // Consumers may only change status (and add timestamp/price fields). Identity
      // fields must stay the same. Allowed transitions:
      //   pending | accepted        → cancelled
      //   pending_completion        → completed (confirm) or disputed (dispute)
      //   price_proposed            → accepted (accept price), price_proposed (counter),
      //                               or cancelled
      allow update: if request.auth != null
                    && resource.data.consumerId == request.auth.uid
                    && request.resource.data.consumerId    == resource.data.consumerId
                    && request.resource.data.providerId    == resource.data.providerId
                    && request.resource.data.serviceId     == resource.data.serviceId
                    && request.resource.data.consumerEmail == resource.data.consumerEmail
                    && (
                         (resource.data.status in ['pending', 'accepted']
                           && request.resource.data.status == 'cancelled')
                      || (resource.data.status == 'pending_completion'
                           && request.resource.data.status in ['completed', 'disputed'])
                      || (resource.data.status == 'price_proposed'
                           && request.resource.data.status in ['accepted', 'price_proposed', 'cancelled'])
                    );

      allow delete: if false;
    }

    // ── Reviews ────────────────────────────────────────────────────────────
    // Anyone can read reviews (shown publicly on service detail pages).
    // Only authenticated consumers can create a review for themselves.
    // The original reviewer may update only rating and comment (not core
    // identity fields). Deletes are not allowed.
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.consumerId == request.auth.uid
                    && request.resource.data.rating is int
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;

      allow update: if request.auth != null
                    && resource.data.consumerId == request.auth.uid
                    && request.resource.data.rating is int
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.serviceId  == resource.data.serviceId
                    && request.resource.data.providerId == resource.data.providerId
                    && request.resource.data.requestId  == resource.data.requestId
                    && request.resource.data.consumerId == resource.data.consumerId;

      allow delete: if false;
    }

    // ── Conversations & Messages ────────────────────────────────────────────
    // Only the two participants can read or write the conversation document.
    // Messages inherit access via a get() check on the parent conversation.
    match /conversations/{conversationId} {
      // Single-doc get: allow when doc doesn't exist yet (resource == null) so
      // getOrCreateConversation can check existence before writing. Participants
      // are enforced on list queries and on the create rule below.
      allow get: if request.auth != null
                 && (resource == null || request.auth.uid in resource.data.participants);
      allow list: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read, create: if request.auth != null
                            && request.auth.uid in
                               get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
                            && (!('text' in request.resource.data)
                                || request.resource.data.text.size() <= 4000);
        allow update, delete: if false;
      }
    }

  }
}
